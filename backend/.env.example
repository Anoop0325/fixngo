# ──────────────────────────────────────────────
# Django Core
# ──────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DB_NAME=fixngo_db
DB_USER=fixngo_user
DB_PASSWORD=fixngo_pass
DB_HOST=localhost
DB_PORT=5432

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000, https://fixngo-theta.vercel.app

# ──────────────────────────────────────────────
# Frontend URL (for CSRF / cookie domain)
# ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
